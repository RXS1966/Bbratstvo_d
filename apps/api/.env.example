SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+psycopg://neuroexam:neuroexam@127.0.0.1:5433/neuroexam

# LLM-оценка кейсов (OpenAI-compatible: /v1/chat/completions)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=90
# Повторы при таймауте/сети (удобно для Ollama): всего попыток = 1 + LLM_MAX_RETRIES
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY_SECONDS=1.5
# DISABLE_LLM=1   # быстрые pytest/E2E без вызовов LLM (как в CI)

# --- Варианты из России (для проверки MVP) ---
# 1) Ollama локально (бесплатно, без VPN):
#    Установите https://ollama.com , затем: ollama pull llama3.2
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# LLM_MODEL=llama3.2
#
# 2) DeepSeek (облако, есть бесплатные кредиты, OpenAI-совместимый API):
# OPENAI_API_KEY=ваш-ключ-с-сайта-deepseek
# OPENAI_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
